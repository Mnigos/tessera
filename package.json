{
  "name": "tessera",
  "version": "0.0.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "packageManager": "bun@1.3.12",
  "engines": {
    "npm": "please-use-bun",
    "yarn": "please-use-bun",
    "bun": ">=1.3.3"
  },
  "scripts": {
    "build": "turbo build",
    "build:web": "bun --filter @repo/web build",
    "build:api": "bun --filter @repo/api build",
    "dev": "turbo dev",
    "dev:web": "bun --filter @repo/web dev",
    "dev:api": "bun --filter @repo/api dev",
    "dev:git": "bun --filter @repo/git-service dev",
    "start": "turbo start",
    "start:web": "bun run --filter @repo/web start",
    "start:api": "bun run --filter @repo/api start",
    "check": "ultracite check",
    "check:fix": "ultracite fix --unsafe",
    "format:rust": "turbo format --filter @repo/git-service",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:api": "bun --filter @repo/api test",
    "db:push": "bun --filter @repo/db db:push",
    "db:migrate": "bun --filter @repo/db db:migrate",
    "db:generate": "bun --filter @repo/db db:generate",
    "db:studio": "bun --filter @repo/db db:studio",
    "docker": "docker compose up --build -V -d",
    "docker:postgres": "docker compose up --build -V postgres -d",
    "docker:postgres:down": "docker compose down",
    "docker:redis": "docker compose up --build -V redis -d",
    "docker:redis:down": "docker compose down",
    "docker:minio": "docker compose up --build -V minio -d",
    "docker:minio:down": "docker compose down",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "prepare": "husky",
    "commit": "cz"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "services/*",
      "tooling/*"
    ],
    "catalog": {
      "typescript": "^5.9.3",
      "tailwindcss": "^4.1.18",
      "@tailwindcss/vite": "^4.1.18",
      "@tailwindcss/postcss": "^4.1.18",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "@types/react": "^19.2.13",
      "@types/react-dom": "^19.2.3",
      "@types/bun": "^1.3.8",
      "@tanstack/react-query": "^5.90.20",
      "@tanstack/react-query-devtools": "^5.91.2",
      "@tanstack/react-router": "^1.158.1",
      "@tanstack/react-start": "^1.158.1",
      "@tanstack/router-plugin": "^1.158.1",
      "@rolldown/plugin-babel": "0.2.2",
      "zod": "^4.1.13",
      "vite": "8.0.2",
      "@hugeicons/core-free-icons": "4.1.3",
      "@hugeicons/react": "1.1.6",
      "lucide-react": "^0.563.0",
      "drizzle-orm": "^0.45.1",
      "@nestjs/common": "^11.1.13",
      "@nestjs/core": "^11.1.13",
      "nitro": "^3.0.1-alpha.2",
      "motion": "^12.33.0",
      "vitest": "4.1.1",
      "@t3-oss/env-core": "^0.13.10",
      "postcss": "^8.5.6",
      "react-icons": "^5.5.0",
      "better-auth": "^1.6.9",
      "@orpc/contract": "1.14.1",
      "hono": "^4.12.16",
      "postgres": "^3.4.8",
      "@vitejs/plugin-react": "6.0.1"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@commitlint/types": "^20.4.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "turbo": "^2.8.3",
    "typescript": "^5.9.3",
    "ultracite": "7.1.4"
  },
  "overrides": {
    "vite": "8.0.2",
    "drizzle-orm": "^0.45.1",
    "@nestjs/core": "catalog:",
    "@nestjs/common": "catalog:"
  },
  "patchedDependencies": {
    "@thallesp/nestjs-better-auth@2.6.0": "patches/@thallesp%2Fnestjs-better-auth@2.6.0.patch"
  }
}
