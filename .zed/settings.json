{
  "tab_size": 2,
  "formatter": {
    "external": {
      "command": "bunx",
      "arguments": ["biome", "format", "--stdin-file-path", "{buffer_path}"]
    }
  },
  "format_on_save": "on",
  "code_actions_on_format": {
    "source.organizeImports.biome": true,
    "source.fixAll.biome": true
  },
  "lsp": {
    "biome": {
      "settings": {
        "require_config_file": true
      }
    }
  },
  "languages": {
    "JSON": {
      "formatter": {
        "external": {
          "command": "bunx",
          "arguments": ["biome", "format", "--stdin-file-path", "{buffer_path}"]
        }
      }
    },
    "JSONC": {
      "formatter": {
        "external": {
          "command": "bunx",
          "arguments": ["biome", "format", "--stdin-file-path", "{buffer_path}"]
        }
      }
    },
    "Rust": {
      "tab_size": 4
    }
  }
}
