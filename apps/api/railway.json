{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "bun run build:api",
    "watchPatterns": [
      "package.json",
      "bun.lock",
      "turbo.json",
      "biome.json",
      "tooling/**",
      "apps/api/**",
      "packages/auth/**",
      "packages/contracts/**",
      "packages/db/**",
      "packages/domain/**",
      "packages/storage/**"
    ]
  },
  "deploy": {
    "preDeployCommand": "bun run db:migrate",
    "startCommand": "bun run start:api",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/health/ping",
    "healthcheckTimeout": 300
  }
}
