{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "bun run build:web",
    "watchPatterns": [
      "package.json",
      "bun.lock",
      "turbo.json",
      "biome.json",
      "tooling/**",
      "apps/web/**",
      "packages/auth/**",
      "packages/contracts/**",
      "packages/domain/**",
      "packages/ui/**"
    ]
  },
  "deploy": {
    "startCommand": "bun run start:web",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/",
    "healthcheckTimeout": 300
  }
}
